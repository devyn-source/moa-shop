# ── Supabase (dedicated moa-shop project — separate from MoaOS). REQUIRED. ──
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Stripe (⚠️ LIVE keys in prod — real charges; test only on /p/test-sku) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
# Leave unset until Stripe Tax + registrations are activated in the dashboard,
# else checkout sessions error.
STRIPE_TAX_ENABLED=

# ── Email (Resend primary; N8N Gmail relay fallback; no-ops if both unset) ──
RESEND_API_KEY=
RESEND_FROM_EMAIL=
N8N_ORDER_EMAIL_WEBHOOK_URL=
CATALOG_OPS_EMAIL=

# ── Auth ──
# Clerk (customer auth target). Public key is safe to expose.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# /admin Basic Auth (proxy.ts). Fails closed in prod if password unset.
ADMIN_USER=
ADMIN_PASSWORD=

# ── Rate limiting (Upstash Redis REST). Limiters are a NO-OP until set —
#    prod logs a warning; once set they enforce (fail-closed in prod).
#    The Vercel Marketplace Upstash integration injects KV_REST_API_URL/_TOKEN
#    automatically (accepted as fallbacks); the UPSTASH_* names also work. ──
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── MoaOS fulfillment pipeline ──
# off | dry_run | draft_only | manual_release | auto  (defaults off — safe)
CATALOG_FULFILLMENT_MODE=
MOAOS_INTAKE_URL=
MOAOS_INTAKE_SECRET=
CRON_SECRET=
INTERNAL_API_SECRET=

# ── moa-pdf (decoration sheets / tech packs) ──
MOA_PDF_URL=
PDF_API_SECRET=

# ── Site ──
NEXT_PUBLIC_SITE_ORIGIN=
# Gates unpublished products (e.g. /p/test-sku) behind ?token=
CATALOG_PREVIEW_TOKEN=

# ── Analytics (all optional; key-gated) ──
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
POSTHOG_API_KEY=
